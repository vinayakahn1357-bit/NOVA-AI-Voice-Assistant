{
  "version": 2,
  "functions": {
    "app.py": {
      "runtime": "@vercel/python",
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "app.py",
      "headers": {
        "Cache-Control": "public, max-age=300, must-revalidate"
      }
    },
    {
      "src": "/chat",
      "dest": "app.py",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "src": "/chat/stream",
      "dest": "app.py",
      "headers": {
        "Cache-Control": "no-store",
        "X-Accel-Buffering": "no"
      }
    },
    {
      "src": "/(.*)",
      "dest": "app.py",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    }
  ]
}
