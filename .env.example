# ─────────────────────────────────────────────
#  NOVA AI — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  DO NOT commit the real .env to version control.
# ─────────────────────────────────────────────

# ── Flask ──────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_PORT=5000
FLASK_SECRET_KEY=change-me-to-a-random-secret-string

# ── Provider Selection ─────────────────────────
# Options: groq | nvidia
NOVA_PROVIDER=groq

# ── Groq Cloud API (REQUIRED — fast default) ───
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── NVIDIA Cloud API (advanced reasoning) ──────
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=nvidia/llama-3.3-70b-instruct

# ── Google OAuth 2.0 ───────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Nova Model Defaults ────────────────────────
NOVA_TEMPERATURE=0.75
NOVA_TOP_P=0.9
NOVA_MAX_TOKENS=1024
NOVA_MAX_HISTORY=30

# ── TTS (Microsoft Edge Neural TTS) ───────────
TTS_DEFAULT_VOICE=en-IN-NeerjaExpressiveNeural
TTS_DEFAULT_RATE=+0%
TTS_DEFAULT_PITCH=+0Hz

# ── Memory ─────────────────────────────────────
MEMORY_FILE=nova_memory.json

# ── Phase 6: Scalable Architecture ─────────────
# PostgreSQL database (leave empty for SQLite fallback)
DATABASE_URL=
# Redis URL (leave empty for in-memory fallback)
REDIS_URL=
# JWT authentication secret (leave empty to disable JWT)
JWT_SECRET_KEY=
JWT_EXPIRY_HOURS=24
# Field encryption key (leave empty for no encryption)
ENCRYPTION_KEY=
# Log format: "text" (local) or "json" (production)
LOG_FORMAT=text
# Background task queue workers (0 = auto-detect)
TASK_QUEUE_WORKERS=0
# Admin emails (comma-separated)
ADMIN_EMAILS=admin@example.com
