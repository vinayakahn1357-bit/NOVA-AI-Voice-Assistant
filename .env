# ─────────────────────────────────────────────
#  NOVA AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  DO NOT commit the real .env to version control.
# ─────────────────────────────────────────────

# ── Flask ──────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
FLASK_PORT=5000
FLASK_SECRET_KEY=change-me-to-a-random-secret-string

# ── Ollama ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_DEFAULT_MODEL=mistral

# ── Nova Model Defaults ────────────────────────
NOVA_TEMPERATURE=0.75
NOVA_TOP_P=0.9
NOVA_MAX_TOKENS=1024
NOVA_MAX_HISTORY=30

# ── TTS (Microsoft Edge Neural TTS) ───────────
TTS_DEFAULT_VOICE=en-IN-NeerjaExpressiveNeural
TTS_DEFAULT_RATE=+0%
TTS_DEFAULT_PITCH=+0Hz

# ── Memory ─────────────────────────────────────
MEMORY_FILE=nova_memory.json
